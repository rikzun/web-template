{
  "include": ["src", "assets.d.ts", "fixes.d.ts"],
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "esnext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": [],

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "sourceMap": true,

    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "paths": {
      "src": ["./src"],
      "src/*": ["./src/*"],
      "@assets": ["./src/assets"],
      "@assets/*": ["./src/assets/*"],
      "@atoms": ["./src/atoms"],
      "@atoms/*": ["./src/atoms/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"],
      "@workers": ["./src/workers"],
      "@workers/*": ["./src/workers/*"],
    },
  },
}
